{
	"name": "hunter-chatgpt-mcp",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"lint": "oxlint src/ bundle/ vite.config.ts",
		"lint:fix": "oxlint --fix src/ bundle/ vite.config.ts",
		"format": "oxfmt --write src/ bundle/ vite.config.ts",
		"format:check": "oxfmt --check src/ bundle/ vite.config.ts",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"type-check": "tsc --noEmit",
		"dev:widgets": "vite",
		"build:widgets": "rm -rf dist/assets && pnpm run build:widgets:company && pnpm run build:widgets:discover",
		"build:widgets:company": "WIDGET_ENTRY=company-widget vite build",
		"build:widgets:discover": "WIDGET_ENTRY=discover-widget vite build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@openai/apps-sdk-ui": "^0.2.1",
		"agents": "^0.8.0",
		"fs-extra": "^11.3.4",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.8.3",
		"vite": "^8.0.0",
		"wrangler": "^4.76.0"
	},
	"overrides": {
		"sugarss": "^5.0.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"workerd"
		]
	}
}
