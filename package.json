{
	"name": "hunter-chatgpt-mcp",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"lint": "oxlint src/ bundle/ vite.config.ts",
		"lint:fix": "oxlint --fix src/ bundle/ vite.config.ts",
		"format": "oxfmt --write src/ bundle/ vite.config.ts",
		"format:check": "oxfmt --check src/ bundle/ vite.config.ts",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"type-check": "tsc --noEmit",
		"test": "vitest run -c vitest.unit.config.mts",
		"test:watch": "vitest -c vitest.unit.config.mts",
		"dev:widgets": "vite",
		"build:widgets": "rm -rf dist/assets && pnpm run build:widgets:company && pnpm run build:widgets:discover",
		"build:widgets:company": "WIDGET_ENTRY=company-widget vite build",
		"build:widgets:discover": "WIDGET_ENTRY=discover-widget vite build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@openai/apps-sdk-ui": "^0.2.2",
		"@sentry/cloudflare": "^10.65.0",
		"fs-extra": "^11.3.6",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"workerd"
		],
		"overrides": {
			"lodash": ">=4.18.0"
		}
	}
}
