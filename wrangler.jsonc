/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "hunter-chatgpt-mcp",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-10",
	// `nodejs_compat` at a compat date >= 2024-09-23 already implies the v2
	// behavior the worker previously opted into via `nodejs_compat_v2`, and it
	// additionally guarantees AsyncLocalStorage — which @sentry/cloudflare needs
	// to bind its per-request scope (HUN-20813). Matches remote-mcp's flag.
	"compatibility_flags": ["nodejs_compat"],
	// The stateless refactor (#12556) dropped the HunterChatGPTMCP Durable
	// Object, but simply removing the `durable_objects` + `migrations` blocks
	// is not enough: the previously-deployed `v1` migration left DOs of that
	// class live in production, so every deploy since then failed with
	// "New version of script does not export class 'HunterChatGPTMCP' which is
	// depended on by existing Durable Objects [code: 10064]". The `v2`
	// delete-class migration below explicitly retires those DOs so the deploy
	// can complete. Keep `v1` in the list so Cloudflare can reconcile history.
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["HunterChatGPTMCP"]
		},
		{
			"tag": "v2",
			"deleted_classes": ["HunterChatGPTMCP"]
		}
	],
	"observability": {
		"enabled": true
	},
	// Sentry error monitoring (HUN-20813). The DSN is an ingest-only public key
	// (send-only, cannot read), safe to commit. Points at the `hunter-chatgpt-mcp`
	// Sentry project — setting it here activates reporting on the next deploy.
	"vars": {
		"SENTRY_DSN": "https://5637f5810d7f2fdb254328234d23fbe2@o36448.ingest.us.sentry.io/4511654793117698",
		"SENTRY_ENVIRONMENT": "production"
	},
	// Exposes the per-deploy version id so @sentry/cloudflare auto-tags each
	// release — works on the Cloudflare Git-integration build with no CI step.
	"version_metadata": {
		"binding": "CF_VERSION_METADATA"
	},
	"alias": {
		"ai": "./src/ai-stub.ts"
	},
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"run_worker_first": true
	}
}
